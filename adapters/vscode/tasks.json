{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "LeetCode: Run",
      "type": "shell",
      "command": "python3 cli/leetcode.py run --problem ${fileDirname}",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "LeetCode: Debug",
      "type": "shell",
      "command": "python3 cli/leetcode.py debug --problem ${fileDirname}",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "LeetCode: Generate Driver",
      "type": "shell",
      "command": "python3 cli/leetcode.py gen --problem ${fileDirname}",
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "LeetCode: Fetch",
      "type": "shell",
      "command": "python3 cli/leetcode.py fetch ${input:problemId}",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "LeetCode: Bench",
      "type": "shell",
      "command": "python3 cli/leetcode.py bench --problem ${fileDirname}",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "LeetCode: Stress Test",
      "type": "shell",
      "command": "python3 cli/leetcode.py stress --problem ${fileDirname}",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "LeetCode: Paste to input.txt",
      "type": "shell",
      "command": "python3 cli/leetcode.py paste --problem ${fileDirname}",
      "group": "none",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "LeetCode: Replay",
      "type": "shell",
      "command": "python3 cli/leetcode.py replay --problem ${fileDirname}",
      "group": "test",
      "presentation": {
        "reveal": "always",
